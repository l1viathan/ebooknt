
<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:ebookdroid="http://ebookdroid.org"
	android:key="book_prefs"
	android:summary="@string/pref_book_category_summary"
	android:title="@string/pref_book_category">

    <EditTextPreference
            android:maxLength="4"
            android:numeric="signed"
            android:defaultValue="@string/pref_book_firstpageoffset_defvalue"
            android:key="@string/pref_book_firstpageoffset_id"
            android:summary="@string/pref_firstpageoffset_summary"
            android:title="@string/pref_firstpageoffset_title" />

    <ListPreference
            android:defaultValue="@string/pref_rotation_unspecified"
            android:entries="@array/pref_book_rotation_entries"
            android:entryValues="@array/pref_book_rotation_values"
            android:key="@string/pref_book_rotation_id"
            android:summary="@string/pref_rotation_summary"
            android:title="@string/pref_rotation_title" />

    <org.emdev.ui.preference.SwitchPreferenceEx
            android:defaultValue="@string/pref_splitpages_defvalue"
            android:key="@string/pref_book_splitpages_id"
            android:summary="@string/pref_splitpages_summary"
            android:title="@string/pref_splitpages_title" />

    <org.emdev.ui.preference.SwitchPreferenceEx
            android:defaultValue="@string/pref_splitpages_rtl_defvalue"
            android:dependency="@string/pref_book_splitpages_id"
            android:key="@string/pref_book_splitpages_rtl_id"
            android:summary="@string/pref_splitpages_rtl_summary"
            android:title="@string/pref_splitpages_rtl_title" />

    <org.emdev.ui.preference.SwitchPreferenceEx
            android:defaultValue="@string/pref_croppages_defvalue"
            android:key="@string/pref_book_croppages_id"
            android:summary="@string/pref_croppages_summary"
            android:title="@string/pref_croppages_title" />

    <ListPreference
            android:defaultValue="@string/pref_viewmode_vertical_scroll"
            android:entries="@array/pref_viewmode_entries"
            android:entryValues="@array/pref_viewmode_values"
            android:key="@string/pref_book_viewmode_id"
            android:summary="@string/pref_viewmode_summary"
            android:title="@string/pref_viewmode_title" />

    <org.emdev.ui.preference.SwitchPreferenceEx
        android:defaultValue="@string/pref_rtl_defvalue"
        android:key="@string/pref_book_rtl_id"
        android:summary="@string/pref_rtl_summary"
        android:title="@string/pref_rtl_title" />

    <org.emdev.ui.preference.SwitchPreferenceEx
        android:defaultValue="@string/pref_textselection_defvalue"
        android:key="@string/pref_book_textselection_id"
        android:summary="@string/pref_textselection_summary"
        android:title="@string/pref_textselection_title" />

	<PreferenceCategory
		android:summary="@string/pref_singlepage_category_summary"
		android:title="@string/pref_singlepage_category">

		<ListPreference
                android:defaultValue="@string/pref_align_auto"
                android:entries="@array/pref_align_entries"
                android:entryValues="@array/pref_align_values"
                android:key="@string/pref_book_align_id"
                android:summary="@string/pref_align_summary"
                android:title="@string/pref_align_title" />

		<ListPreference
                android:defaultValue="@string/pref_animation_type_none"
                android:entries="@array/pref_animation_type_entries"
                android:entryValues="@array/pref_animation_type_values"
                android:key="@string/pref_book_animation_type_id"
                android:summary="@string/pref_animationtype_summary"
                android:title="@string/pref_animationtype_title" />
	</PreferenceCategory>

    <PreferenceCategory
        android:summary="@string/pref_postprocessing_summary"
        android:title="@string/pref_postprocessing_category" >

        <org.emdev.ui.preference.SwitchPreferenceEx
            android:defaultValue="@string/pref_nightmode_defvalue"
            android:key="@string/pref_book_nightmode_id"
            android:summary="@string/pref_nightmode_summary"
            android:title="@string/pref_nightmode_title" />

        <org.emdev.ui.preference.SwitchPreferenceEx
            android:defaultValue="@string/pref_posimages_in_nightmode_defvalue"
            android:key="@string/pref_book_posimages_in_nightmode_id"
            android:summary="@string/pref_posimages_in_nightmode_summary"
            android:title="@string/pref_posimages_in_nightmode_title" />

        <org.emdev.ui.preference.SwitchPreferenceEx
            android:defaultValue="@string/pref_tint_defvalue"
            android:key="@string/pref_book_tint_id"
            android:summary="@string/pref_tint_summary"
            android:title="@string/pref_tint_title" />

        <org.emdev.ui.preference.ColorPickerPreference
            android:key="@string/pref_book_tint_color_id"
            android:summary="@string/pref_tint_color_summary"
            android:title="@string/pref_tint_color_title" />

        <Preference
            android:key="pref_picture_enhancement"
            android:summary="@string/pref_picture_enhancement_summary"
            android:title="@string/pref_picture_enhancement_title"
            android:widgetLayout="@layout/pref_widget_arrow" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/pref_templates_category">

        <Preference
            android:key="pref_template_apply"
            android:title="@string/pref_template_apply_title"/>

        <Preference
            android:key="pref_template_save"
            android:title="@string/pref_template_save_title"/>

    </PreferenceCategory>

</PreferenceScreen>