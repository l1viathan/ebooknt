<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/gotopageView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#E0303030">

    <!-- Bookmarks header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dip"
        android:orientation="horizontal">

        <View
            android:id="@+id/bookmark_add"
            android:layout_width="40dip"
            android:layout_height="40dip"
            android:layout_marginLeft="4dip"
            android:layout_marginRight="2dip"
            android:background="@drawable/viewer_goto_dlg_bookmark_add"/>

        <TextView
            android:layout_width="0dip"
            android:layout_height="40dip"
            android:layout_gravity="center"
            android:layout_marginLeft="2dip"
            android:layout_marginRight="2dip"
            android:layout_weight="1.0"
            android:gravity="center"
            android:singleLine="true"
            android:text="@string/bookmarks_title"
            android:textSize="18dip"
            android:textStyle="bold"/>

        <View
            android:id="@+id/bookmark_remove_all"
            android:layout_width="40dip"
            android:layout_height="40dip"
            android:layout_marginLeft="2dip"
            android:layout_marginRight="4dip"
            android:background="@drawable/viewer_goto_dlg_bookmark_remove_all"/>
    </LinearLayout>

    <!-- Bookmarks list -->
    <ListView
        android:id="@+id/bookmarks"
        android:layout_width="match_parent"
        android:layout_height="60dip"
        android:layout_marginLeft="4dip"
        android:layout_marginRight="4dip"/>

    <!-- Minus / SeekBar / Plus -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/seekbar_minus"
            android:layout_width="48dip"
            android:layout_height="48dip"
            android:layout_alignParentLeft="true"
            android:layout_marginLeft="4dip"
            android:layout_marginRight="4dip"
            android:background="@drawable/components_seekbar_minus"/>

        <LinearLayout
            android:id="@+id/seekbar_plus"
            android:layout_width="48dip"
            android:layout_height="48dip"
            android:layout_alignParentRight="true"
            android:layout_marginLeft="4dip"
            android:layout_marginRight="4dip"
            android:background="@drawable/components_seekbar_plus"/>

        <SeekBar
            android:id="@+id/seekbar"
            android:layout_width="match_parent"
            android:layout_height="48dip"
            android:layout_toRightOf="@id/seekbar_minus"
            android:layout_toLeftOf="@id/seekbar_plus"
            android:layout_marginLeft="16dip"
            android:layout_marginRight="16dip"
            android:gravity="center"
            android:minHeight="48dip"
            android:maxHeight="48dip"/>
    </RelativeLayout>

    <!-- Page number input + Go button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dip"
        android:layout_marginBottom="2dip"
        android:layout_marginLeft="4dip"
        android:layout_marginRight="4dip"
        android:gravity="center"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/pageNumberTextEdit"
            android:layout_width="0dip"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginRight="4dip"
            android:layout_weight="1"
            android:inputType="number"
            android:minEms="4"
            android:numeric="integer"
            android:textSize="24dip"
            android:textStyle="bold"
            android:gravity="center"/>

        <LinearLayout
            android:id="@+id/goToButton"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/viewer_goto_dlg_goto_background"
            android:gravity="center">

            <ImageView
                android:layout_width="40dip"
                android:layout_height="40dip"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="8dip"
                android:src="@drawable/viewer_goto_dlg_goto"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="4dip"
                android:layout_marginRight="8dip"
                android:ellipsize="marquee"
                android:gravity="center_vertical"
                android:text="@string/button_goto_page"
                android:textSize="22dip"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
