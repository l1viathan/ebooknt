<?xml version="1.0" encoding="utf-8"?>
<!-- DrawerLayout root: right-edge swipe reveals open books + library -->
<android.support.v4.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/viewer_drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content -->
    <FrameLayout
        android:id="@+id/viewer_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Toolbar stacked above GL view; toolbar topMargin is set at runtime
             to push it below the status bar (via window insets listener). -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <include layout="@layout/toolbar_actionbar" />

            <FrameLayout
                android:id="@+id/framelayout"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

    </FrameLayout>

    <!-- Outline drawer (left) -->
    <LinearLayout
        android:id="@+id/viewer_outline_drawer"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#60303030">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="12dp"
            android:paddingRight="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <EditText
                android:id="@+id/outline_drawer_search"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:inputType="text"
                android:singleLine="true"
                android:textSize="14sp"
                android:textColor="#FFFFFFFF"
                android:textColorHint="#80FFFFFF"
                android:hint="搜索"
                android:background="@android:color/transparent"
                android:paddingLeft="4dp" />

            <CheckBox
                android:id="@+id/outline_drawer_preview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="预览"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:checked="true" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#40FFFFFF" />

        <ListView
            android:id="@+id/outline_drawer_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:choiceMode="singleChoice"
            android:cacheColorHint="#00000000"
            android:divider="@null"
            android:fastScrollEnabled="true" />

        <Button
            android:id="@+id/outline_drawer_confirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="确定"
            android:textColor="#FFFFFFFF"
            android:background="#40606060"
            android:layout_margin="8dp" />

    </LinearLayout>

    <!-- Open books drawer (right) -->
    <ListView
        android:id="@+id/viewer_drawer_list"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#FE303030"
        android:divider="#505050"
        android:dividerHeight="1dp" />

</android.support.v4.widget.DrawerLayout>
