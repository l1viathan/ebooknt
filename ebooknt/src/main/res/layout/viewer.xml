<?xml version="1.0" encoding="utf-8"?>
<!-- DrawerLayout root: left-swipe reveals open books + library -->
<android.support.v4.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/viewer_drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content -->
    <FrameLayout
        android:id="@+id/viewer_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Toolbar stacked above GL view; toolbar topMargin is set at runtime
             to push it below the status bar (via window insets listener). -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <include layout="@layout/toolbar_actionbar" />

            <FrameLayout
                android:id="@+id/framelayout"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

    </FrameLayout>

    <!-- Navigation drawer -->
    <ListView
        android:id="@+id/viewer_drawer_list"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FAFAFA"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp" />

</android.support.v4.widget.DrawerLayout>
