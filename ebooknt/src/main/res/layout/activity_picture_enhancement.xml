<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FF333333"
        android:paddingStart="4dp"
        android:paddingEnd="8dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/recent_bookcase_nav_prev"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:contentDescription="@null" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btn_reset"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/pic_enhance_reset"
            android:textColor="#FFFFFFFF"
            style="?android:attr/borderlessButtonStyle" />

        <Button
            android:id="@+id/btn_default"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/pic_enhance_default"
            android:textColor="#FFFFFFFF"
            style="?android:attr/borderlessButtonStyle" />
    </LinearLayout>

    <!-- Preview image -->
    <ImageView
        android:id="@+id/preview_image"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:scaleType="fitCenter"
        android:background="#FF000000"
        android:contentDescription="@string/pref_picture_enhancement_title" />

    <!-- Controls area: 6 rows evenly distributed -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <!-- Contrast: -2.55 to 2.55 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="@string/pref_contrast_title"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-2.55"
                android:textSize="10sp"
                android:textColor="#FF888888" />

            <Button
                android:id="@+id/btn_contrast_minus"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="-"
                android:textSize="14sp" />

            <SeekBar
                android:id="@+id/seek_contrast"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="510"
                android:progress="255" />

            <Button
                android:id="@+id/btn_contrast_plus"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="+"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2.55"
                android:textSize="10sp"
                android:textColor="#FF888888" />

            <TextView
                android:id="@+id/label_contrast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:minWidth="44dp"
                android:text="0.00"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Gamma: 0.00 to 2.00 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="@string/pref_gamma_title"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00"
                android:textSize="10sp"
                android:textColor="#FF888888" />

            <Button
                android:id="@+id/btn_gamma_minus"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="-"
                android:textSize="14sp" />

            <SeekBar
                android:id="@+id/seek_gamma"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="200"
                android:progress="100" />

            <Button
                android:id="@+id/btn_gamma_plus"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="+"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2.00"
                android:textSize="10sp"
                android:textColor="#FF888888" />

            <TextView
                android:id="@+id/label_gamma"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:minWidth="44dp"
                android:text="1.00"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Exposure: -1.28 to 1.28 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="@string/pref_exposure_title"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-1.28"
                android:textSize="10sp"
                android:textColor="#FF888888" />

            <Button
                android:id="@+id/btn_exposure_minus"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="-"
                android:textSize="14sp" />

            <SeekBar
                android:id="@+id/seek_exposure"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="256"
                android:progress="128" />

            <Button
                android:id="@+id/btn_exposure_plus"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="+"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.28"
                android:textSize="10sp"
                android:textColor="#FF888888" />

            <TextView
                android:id="@+id/label_exposure"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:minWidth="44dp"
                android:text="0.00"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Auto levels -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/pref_autolevels_title"
                android:textSize="13sp" />

            <Switch
                android:id="@+id/switch_autolevels"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Threshold: 0.00 to 0.50 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="@string/pref_threshold_title"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00"
                android:textSize="10sp"
                android:textColor="#FF888888" />

            <Button
                android:id="@+id/btn_threshold_minus"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="-"
                android:textSize="14sp" />

            <SeekBar
                android:id="@+id/seek_threshold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="50"
                android:progress="0" />

            <Button
                android:id="@+id/btn_threshold_plus"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="+"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.50"
                android:textSize="10sp"
                android:textColor="#FF888888" />

            <TextView
                android:id="@+id/label_threshold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:minWidth="44dp"
                android:text="0.00"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Smoothness: 1.00 to 8.00 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="@string/pref_smoothness_title"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.00"
                android:textSize="10sp"
                android:textColor="#FF888888" />

            <Button
                android:id="@+id/btn_smoothness_minus"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="-"
                android:textSize="14sp" />

            <SeekBar
                android:id="@+id/seek_smoothness"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="700"
                android:progress="0" />

            <Button
                android:id="@+id/btn_smoothness_plus"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="+"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8.00"
                android:textSize="10sp"
                android:textColor="#FF888888" />

            <TextView
                android:id="@+id/label_smoothness"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:minWidth="44dp"
                android:text="1.00"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
